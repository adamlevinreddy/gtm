# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# GitHub (PAT with repo scope for Reddy-GTM repo)
GITHUB_TOKEN=
GITHUB_OWNER=ReddySolutions
GITHUB_REPO=gtm
GITHUB_BRANCH=main

# Slack App
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Proactive features (morning digest + post-meeting suggestions)
# Channel the proactive bot posts to. Set to the sales-testing channel for
# testing (resolve its Cxxxx id from Slack); falls back to SLACK_CHANNEL_ID.
SALES_TESTING_CHANNEL_ID=
# Optional explicit digest channel override (else SALES_TESTING_CHANNEL_ID)
DIGEST_SLACK_CHANNEL_ID=
# Shared secret for the cron route. Vercel sends `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=
# Where the tracking board lives. Defaults to this app's own /board stub.
TRACKING_BOARD_URL=https://gtm-jet.vercel.app/board
# Teammate the digest's "focus today" agent runs as (uses their sandbox +
# connected tools, read-only). If unset, focus falls back to a deterministic
# top-priority pick. Requires MCP_INTERNAL_SECRET (already set for the MCP).
DIGEST_AGENT_EMAIL=adam@reddy.io

# Vercel KV (auto-populated when linked)
KV_REST_API_URL=
KV_REST_API_TOKEN=
